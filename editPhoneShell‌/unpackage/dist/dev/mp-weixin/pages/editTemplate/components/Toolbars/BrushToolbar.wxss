
.toolbar-card.data-v-086c4aa2 {
		padding: 24rpx;
		border-radius: 32rpx;
		background: rgba(255, 255, 255, 0.9);
		box-shadow: 0 18rpx 60rpx rgba(80, 56, 30, 0.08);
}

	/* 下层内容样式 */
.toolbar-bottom.data-v-086c4aa2 {
		padding-top: 10rpx;
}
.nav-content.data-v-086c4aa2 {
		padding: 10rpx 0;
}
.color-row.data-v-086c4aa2,
	.toolbar-actions.data-v-086c4aa2 {
		display: flex;
		flex-wrap: wrap;
		gap: 16rpx;
		align-items: center;
}
.color-chip.data-v-086c4aa2 {
		width: 48rpx;
		height: 48rpx;
		border-radius: 999rpx;
