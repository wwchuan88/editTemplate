		border-color: #f2e7da;
		box-shadow: 0 0 0 4rpx #d86e33;
}

	/* 滑动输入条样式 */
.size-slider.data-v-086c4aa2 {
		padding: 10rpx 0;
}
.size-label.data-v-086c4aa2 {
		display: block;
		margin-bottom: 16rpx;
		font-size: 24rpx;
		color: #6d594d;
		text-align: center;
}
.slider-container.data-v-086c4aa2 {
		padding: 0 20rpx;
}

	/* 自定义滑块样式 */
.slider.data-v-086c4aa2 {
		width: 100%;
		height: 8rpx;
		background: #f2e7da;
		border-radius: 4rpx;
		outline: none;
		-webkit-appearance: none;
}
.slider.data-v-086c4aa2::-webkit-slider-thumb {
		-webkit-appearance: none;
		appearance: none;
		width: 32rpx;
		height: 32rpx;
		background: #d86e33;
		border-radius: 50%;
		cursor: pointer;
		box-shadow: 0 2rpx 8rpx rgba(216, 110, 51, 0.3);
}
.slider.data-v-086c4aa2::-moz-range-thumb {
		width: 32rpx;
		height: 32rpx;
		background: #d86e33;
		border-radius: 50%;
		cursor: pointer;
		border: none;
		box-shadow: 0 2rpx 8rpx rgba(216, 110, 51, 0.3);
}
