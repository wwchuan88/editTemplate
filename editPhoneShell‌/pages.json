{
	"easycom": {
		"autoscan": true,
		"custom": {
			"^u-(.*)": "@/uni_modules/uview-plus_3.8.9/components/u-$1/u-$1.vue",
			"^up-(.*)": "@/uni_modules/uview-plus_3.8.9/components/u-$1/u-$1.vue"
		}
	},
	"pages": [ //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
		{
			"path": "pages/productShow/productShow",
			"style": {
				"navigationBarTitleText": "灵感广场"
			}
		},
		{
			"path": "pages/choose/choose",
			"style": {
				"navigationBarTitleText": "选择型号"
			}
		},
		{
			"path": "pages/choose/choseEditTemplate",
			"style": {
				"navigationBarTitleText": "选择模板"
			}
		},
		{
			"path": "pages/login/login",
			"style": {
				"navigationBarTitleText": "店管家手机端",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/editTemplate/editTemplate",
			"style": {
				"navigationBarTitleText": "店管家手机端"
			}
		},
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "uni-app"
			}
		},
		{
			"path": "pages/index/indexPage",
			"style": {
				"navigationBarTitleText": "首页"
			}
		},
		{
			"path": "pages/ai/aiCreatePic",
			"style": {
				"navigationBarTitleText": "AI生图"
			}
		},
		{
			"path": "pages/tabbar/mine",
			"style": {
				"navigationBarTitleText": "我的"
			}
		}
	],
	"tabBar": {
		"color": "#748094",
		"selectedColor": "#182433",
		"backgroundColor": "#F8FAFD",
		"borderStyle": "black",
		"list": [
			{
				"pagePath": "pages/index/indexPage",
				"text": "首页"
			},
			{
				"pagePath": "pages/productShow/productShow",
				"text": "灵感广场"
			},
			{
				"pagePath": "pages/choose/choose",
				"text": "编辑模板"
			},
			{
				"pagePath": "pages/ai/aiCreatePic",
				"text": "AI生图"
			},
			{
				"pagePath": "pages/tabbar/mine",
				"text": "我的"
			}
		]
	},
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "uni-app",
		"navigationBarBackgroundColor": "#F8F8F8",
		"backgroundColor": "#F8F8F8"
	},
	"uniIdRouter": {},
	"condition": { //模式配置，仅开发期间生效
		"current": 0, //当前激活的模式(list 的索引项)
		"list": [
			{
				"name": "", //模式名称
				"path": "", //启动页面，必选
				"query": "" //启动参数，在页面的onLoad函数里面得到
			}
		]
	}
}